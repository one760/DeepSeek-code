{
  "name": "deepseek-code",
  "version": "0.1.0",
  "description": "Interactive coding CLI for DeepSeek with tools, sessions, and terminal UI",
  "type": "module",
  "license": "MIT",
  "bin": {
    "deepseek": "dist/cli/bin/deepseek.js",
    "deepseek-code": "dist/cli/bin/deepseek-code.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/bin/deepseek.ts code",
    "start": "node dist/cli/bin/deepseek.js code",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "env-paths": "^4.0.0",
    "fast-glob": "^3.3.3",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "openai": "^6.33.0",
    "react": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
